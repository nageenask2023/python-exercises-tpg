import matplotlib.pyplot as plt
import seaborn as sns
import pandas as pd

# IRIS DATASET
iris = sns.load_dataset('iris')

# Histogram of sepal_length
plt.figure()
sns.histplot(iris['sepal_length'], bins=10)
plt.title("Histogram of Sepal Length")
plt.savefig('images/iris_sepal_length_hist.png')

# Bar chart of mean values per species
plt.figure()
iris.groupby('species').mean().plot(kind='bar')
plt.title("Mean Feature Values per Species")
plt.savefig('images/iris_mean_features_bar.png')

# Scatter plot sepal length vs width
plt.figure()
sns.scatterplot(data=iris, x='sepal_length', y='sepal_width', hue='species')
plt.title("Sepal Length vs Width")
plt.savefig('images/iris_sepal_scatter.png')

# Boxplot of petal width
plt.figure()
sns.boxplot(x='species', y='petal_width', data=iris)
plt.title("Boxplot of Petal Width")
plt.savefig('images/iris_petal_width_box.png')

# Violin plots
plt.figure()
sns.violinplot(x='species', y='sepal_length', data=iris)
plt.title("Violin Plot of Sepal Length")
plt.savefig('images/iris_sepal_length_violin.png')

plt.figure()
sns.violinplot(x='species', y='sepal_width', data=iris)
plt.title("Violin Plot of Sepal Width")
plt.savefig('images/iris_sepal_width_violin.png')

# DIAMONDS DATASET
diamonds = sns.load_dataset('diamonds')

# Scatter plot carat vs price
plt.figure()
sns.scatterplot(x='carat', y='price', data=diamonds)
plt.title("Scatter Plot: Carat vs Price")
plt.savefig('images/diamonds_carat_price_scatter.png')

# Histogram price with mean line
plt.figure()
sns.histplot(diamonds['price'], bins=30)
plt.axvline(diamonds['price'].mean(), color='red', linestyle='--')
plt.title("Histogram of Price with Mean Line")
plt.savefig('images/diamonds_price_hist.png')

# Bar plot count by cut
plt.figure()
sns.countplot(x='cut', data=diamonds)
plt.title("Count of Diamonds by Cut")
plt.savefig('images/diamonds_cut_bar.png')

# Box plot price by cut
plt.figure()
sns.boxplot(x='cut', y='price', data=diamonds)
plt.title("Boxplot of Price by Cut")
plt.savefig('images/diamonds_price_box.png')

# Heatmap of correlation
plt.figure()
sns.heatmap(diamonds.corr(), annot=True, cmap='coolwarm')
plt.title("Correlation Heatmap")
plt.savefig('images/diamonds_corr_heatmap.png')

# Line plot average price per carat for each cut
plt.figure()
diamonds.groupby('cut').apply(lambda x: x.groupby('carat')['price'].mean()).unstack(level=0).plot()
plt.title("Average Price per Carat per Cut")
plt.savefig('images/diamonds_avg_price_line.png')

# Stacked bar: count by cut and color
plt.figure()
pd.crosstab(diamonds['cut'], diamonds['color']).plot(kind='bar', stacked=True)
plt.title("Stacked Bar: Cut vs Color")
plt.savefig('images/diamonds_cut_color_stacked.png')

# Histogram of carat distribution by color
plt.figure()
sns.histplot(data=diamonds, x='carat', hue='color', element='step', multiple='stack')
plt.title("Carat Distribution by Color")
plt.savefig('images/diamonds_carat_color_hist.png')

print("All plots saved in 'images/' folder")
