import pandas as pd
import numpy as np

# Load dataset
url = 'https://raw.githubusercontent.com/justmarkham/DAT8/master/data/chipotle.tsv'
food = pd.read_csv(url, sep='\t')

# DATA EXPLORATION 
print(food.head())
print(food.tail())
print(food.columns)
print(food.info())
print("\nCheck for NaNs:\n", food.isnull().sum())
print("\nCheck for duplicates:\n", food.duplicated().sum())

# Fill NaNs
food.fillna("Not specified", inplace=True)

# Convert item_price to float
food['item_price'] = food['item_price'].str.replace('$', '').astype(float)

# Create new column: price per item
food['price_per_item'] = food['item_price'] / food['quantity']

# DATA ANALYSIS
# Statistical description
print(food.describe())

# 10 most ordered items
top_items = food.groupby('item_name').quantity.sum().sort_values(ascending=False).head(10)
print("\nTop 10 items:\n", top_items)

# Total items ordered
total_items = food['quantity'].sum()
print("\nTotal items ordered:", total_items)

# Total revenue
total_revenue = food['item_price'].sum()
print("Total revenue: $", total_revenue)

# Average revenue per order
avg_revenue = food.groupby('order_id')['item_price'].sum().mean()
print("Average revenue per order: $", round(avg_revenue, 2))

# Save cleaned DataFrame
food.to_csv('data/Exercise2_Cleaned.csv', index=False)
print("\nCleaned Chipotle data saved to data/Exercise2_Cleaned.csv")
